# ProcureMind AI Production Environment Configuration Template
# Copy this file to .env.production and populate the values securely.

# Environment execution mode (set to "production" to enable strict checks and worker matrix)
ENV_MODE=production

# Asynchronous connection string to the production PostgreSQL container or Supabase
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password_here@pm-db:5432/procuremind_db

# LLM provider configurations for the memory bridge and copilot chat
# Only the key corresponding to COPILOT_LLM_MODEL is strictly verified on startup.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Active copilot LLM model routing identifier (e.g. gpt-4o-mini, gemini/gemini-2.5-flash)
COPILOT_LLM_MODEL=gpt-4o-mini
COPILOT_LLM_TIMEOUT_SECONDS=20
