# -----------------------------------------------------------------------------
# AegisProcure Production Environment Template (Multi-Provider Cloud Stack)
# -----------------------------------------------------------------------------

# Database Service Connection Path (e.g. Neon Serverless Postgres with pg_bypass / transaction pooling)
DATABASE_URL="postgresql://<user>:<password>@<neon-host>/procuremind_db?sslmode=require"

# Backend CORS Allowed Origins (Comma-separated Vercel public client origins)
ALLOWED_ORIGINS="https://your-frontend-domain.vercel.app,http://localhost:3001"

# Frontend Next.js Public Routing Target (Render live backend URL)
NEXT_PUBLIC_API_URL="https://pm-backend.onrender.com"

# LiteLLM Platform Keys (Credential targets evaluated at startup runtime)
OPENAI_API_KEY="your-openai-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"

# Operational Mode
ENV_MODE="production"
PORT="8000"
